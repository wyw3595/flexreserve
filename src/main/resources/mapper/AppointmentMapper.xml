<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.flexreserve.appointment.mapper.AppointmentMapper">


    <select id="selectByUserId" resultType="com.flexreserve.appointment.entity.Appointment">
        SELECT * FROM biz_appointment
        WHERE user_id = #{userId}
        ORDER BY appointment_time DESC
    </select>
</mapper>