<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.flexreserve.appointment.mapper.ResourceMapper">


    <select id="getResourceList" resultType="com.flexreserve.appointment.entity.vo.Resource">
        SELECT
            id,
            name,
            type,
            capacity,
            location,
            equipment,
            status
        FROM biz_resource
        WHERE status = 1
          AND is_deleted = 0
        ORDER BY create_time DESC 
    </select>
</mapper>